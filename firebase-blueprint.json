{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "role"]
    },
    "Trip": {
      "title": "Trip",
      "description": "A travel trip",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "collaborator_ids": { "type": "array", "items": { "type": "string" } },
        "title": { "type": "string" },
        "days": { "type": "string" },
        "start_date": { "type": "string" },
        "created_at": { "type": "string" }
      },
      "required": ["user_id", "title"]
    },
    "ItineraryItem": {
      "title": "ItineraryItem",
      "description": "An item in the itinerary",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "day_id": { "type": "string" },
        "place_name": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "order_index": { "type": "number" },
        "notes": { "type": "string" },
        "note_images": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["trip_id", "place_name", "lat", "lng", "order_index"]
    },
    "ExpenseItem": {
      "title": "ExpenseItem",
      "description": "An expense item in the trip",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "day_id": { "type": "string" },
        "item_name": { "type": "string" },
        "amount": { "type": "number" },
        "payer": { "type": "string" },
        "order_index": { "type": "number" }
      },
      "required": ["trip_id", "day_id", "item_name", "amount", "payer", "order_index"]
    },
    "PackingItem": {
      "title": "PackingItem",
      "description": "A packing list item in the trip",
      "type": "object",
      "properties": {
        "trip_id": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "is_checked": { "type": "boolean" },
        "order_index": { "type": "number" }
      },
      "required": ["trip_id", "name", "quantity", "is_checked", "order_index"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/trips/{tripId}": {
      "schema": { "$ref": "Trip" },
      "description": "Trips"
    },
    "/trips/{tripId}/items/{itemId}": {
      "schema": { "$ref": "ItineraryItem" },
      "description": "Itinerary items"
    },
    "/trips/{tripId}/expenses/{expenseId}": {
      "schema": { "$ref": "ExpenseItem" },
      "description": "Trip expenses"
    },
    "/trips/{tripId}/packingList/{itemId}": {
      "schema": { "$ref": "PackingItem" },
      "description": "Trip packing list items"
    },
    "/trips/{tripId}/collaborators/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Trip collaborators"
    }
  }
}
