# GEMINI_API_KEY: Required for Gemini AI API calls.
# Inside AI Studio: This is automatically injected from user secrets.
# Outside AI Studio (Local/Deployed): You MUST provide your own API key.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_MAPS_API_KEY: Required for Google Maps and Places Autocomplete.
VITE_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"
