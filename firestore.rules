rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isCollaborator(data) {
      return isAuthenticated() && data.get('collaborator_ids', []).hasAny([request.auth.uid]);
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "xkoukix111@gmail.com" && request.auth.token.email_verified == true));
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) && hasRequiredFields(['email', 'role']) && hasOnlyAllowedFields(['email', 'role']) && request.resource.data.role in ['user', 'admin'];
    }

    match /users_public/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    match /trips/{tripId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isCollaborator(resource.data));
      allow create: if isAuthenticated() && (request.resource.data.user_id == request.auth.uid) && hasRequiredFields(['user_id', 'title']) && hasOnlyAllowedFields(['user_id', 'title', 'days', 'collaborator_ids']) && validStringLength('title', 1, 100);
      allow update: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isCollaborator(resource.data)) && hasRequiredFields(['user_id', 'title']) && hasOnlyAllowedFields(['user_id', 'title', 'days', 'collaborator_ids']) && validStringLength('title', 1, 100) && request.resource.data.user_id == resource.data.user_id;
      allow delete: if isAuthenticated() && (resource.data.user_id == request.auth.uid || isCollaborator(resource.data));

      match /items/{itemId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data)) && hasRequiredFields(['trip_id', 'place_name', 'lat', 'lng', 'order_index']) && hasOnlyAllowedFields(['trip_id', 'place_name', 'lat', 'lng', 'order_index', 'day_id', 'stay_duration', 'travel_time', 'notes']) && validStringLength('place_name', 1, 100) && request.resource.data.lat is number && request.resource.data.lng is number && request.resource.data.order_index is number;
        allow update: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
        allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
      }
      match /expenses/{expenseId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data)) && hasRequiredFields(['trip_id', 'day_id', 'item_name', 'amount', 'payer', 'order_index']) && hasOnlyAllowedFields(['trip_id', 'day_id', 'item_name', 'amount', 'payer', 'order_index']) && validStringLength('item_name', 1, 100) && request.resource.data.amount is number && request.resource.data.order_index is number;
        allow update: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
        allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
      }
      match /packingList/{itemId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
        allow create: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data)) && hasRequiredFields(['trip_id', 'name', 'quantity', 'is_checked', 'order_index']) && hasOnlyAllowedFields(['trip_id', 'name', 'quantity', 'is_checked', 'order_index', 'category']) && validStringLength('name', 1, 100) && request.resource.data.quantity is number && request.resource.data.is_checked is bool && request.resource.data.order_index is number && (!('category' in request.resource.data) || request.resource.data.category is string);
        allow update: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data)) && (!('name' in request.resource.data) || validStringLength('name', 1, 100)) && (!('quantity' in request.resource.data) || request.resource.data.quantity is number) && (!('is_checked' in request.resource.data) || request.resource.data.is_checked is bool) && (!('order_index' in request.resource.data) || request.resource.data.order_index is number) && (!('trip_id' in request.resource.data) || request.resource.data.trip_id == resource.data.trip_id) && (!('category' in request.resource.data) || request.resource.data.category is string);
        allow delete: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
      }
      match /collaborators/{userId} {
        allow read: if isAuthenticated() && (get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid || isCollaborator(get(/databases/$(database)/documents/trips/$(tripId)).data));
        allow write: if isAuthenticated() && get(/databases/$(database)/documents/trips/$(tripId)).data.user_id == request.auth.uid;
      }
    }
  }
}
